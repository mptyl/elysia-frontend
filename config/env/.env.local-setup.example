# ============================================================
# PARAMETRI ATTIVI — usati dal codice dell'applicazione
# ============================================================

# ---- Auth provider (obbligatorio: emulator | entra) ----
## !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
## !! MODALITA' ATTIVA: ENTRA ID REALE (Microsoft)                      !!
## !!                                                                    !!
## !! PER PASSARE ALL'EMULATORE LOCALE:                                 !!
## !!   1. Qui sotto: commentare la riga ENTRA ID,                      !!
## !!      decommentare la riga EMULATORE                               !!
## !!   2. Blocco Directory Service (poco sotto):                        !!
## !!      commentare le 5 righe ENTRA ID REALE,                        !!
## !!      decommentare le 2 righe EMULATORE LOCALE                     !!
## !!   3. Blocco MODALITA' EMULATORE in fondo a questo file:           !!
## !!      decommentare le 3 righe ENTRA_EMULATOR*                      !!
## !!   4. supabase-project/.env → blocco OPTION B:                     !!
## !!      commentare le 3 righe ENTRA ID REALE,                        !!
## !!      decommentare le 3 righe EMULATORE LOCALE                     !!
## !!   5. docker compose restart auth   (da supabase-project/)         !!
## !!   6. Riavviare il frontend (npm run dev)                          !!
## !!   Credenziali test: demo@uni.local / demo123                      !!
## !!   (anche: marco, simone, leo, sofia, lisa — password: {nome}123)  !!
## !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#NEXT_PUBLIC_AUTH_PROVIDER=entra
NEXT_PUBLIC_AUTH_PROVIDER=emulator

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
SUPABASE_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY={placeholder}

# ---- Backend Elysia ----
ELYSIA_INTERNAL_URL=http://127.0.0.1:8090
NEXT_PUBLIC_ELYSIA_WS_PORT=8090

# ---- ThothAI integration ----
NEXT_PUBLIC_THOTH_URL=http://localhost:3040

# ---- Directory Service (profile sync via Microsoft Graph API) ----
## -- ENTRA ID REALE (commentato) --
#DIRECTORY_SERVICE_URL=https://graph.microsoft.com
#DIRECTORY_SERVICE_AUTH_MODE=bearer
#AZURE_TENANT_ID={your-azure-tenant-id}
#AZURE_CLIENT_ID={your-azure-client-id}
#AZURE_CLIENT_SECRET={your-azure-client-secret}
## -- EMULATORE LOCALE (attivo) --
DIRECTORY_SERVICE_URL=http://host.docker.internal:8029
DIRECTORY_SERVICE_AUTH_MODE=none

# ---- Binding del dev server (usati solo da npm scripts) ----
APP_BIND_HOST=0.0.0.0
APP_BIND_PORT=3090

# ============================================================
# PARAMETRI CON DEFAULT NEL CODICE — decommentare solo per override
# ============================================================
# AUTH_PROVIDER_MODE=entra                          # ridondante: fallback server-side di NEXT_PUBLIC_AUTH_PROVIDER
# NEXT_PUBLIC_OAUTH_REDIRECT_PATH=/auth/callback    # default gia' nel codice: /auth/callback
# NEXT_PUBLIC_SUPABASE_AUTH_COOKIE_NAME=sb-athena-auth-token  # default gia' nel codice

# ============================================================
# MODALITA' EMULATORE — attualmente NON ATTIVA (Entra ID reale in uso)
#
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# !! PER TORNARE A ENTRA ID REALE:                         !!
# !!   1. Commentare NEXT_PUBLIC_AUTH_PROVIDER=emulator    !!
# !!      e decommentare NEXT_PUBLIC_AUTH_PROVIDER=entra   !!
# !!   2. Commentare le 3 righe ENTRA_EMULATOR qui sotto   !!
# !!   3. Ripristinare il blocco Directory Service:        !!
# !!      commentare le 2 righe EMULATORE                  !!
# !!      decommentare le 5 righe ENTRA ID REALE           !!
# !!   4. In supabase-project/.env: vedere il blocco       !!
# !!      analogo (commentare emulatore, decommentare entra)!!
# !!   5. Eseguire: docker compose restart auth            !!
# !!   6. Riavviare il frontend (npm run dev)              !!
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#
# Credenziali test emulatore: demo@uni.local / demo123
#   (marco, simone, leo, sofia, lisa — password: {nome}123)
# ============================================================
ENTRA_EMULATOR_INTERNAL_HOST=http://host.docker.internal:8029
NEXT_PUBLIC_ENTRA_EMULATOR_PUBLIC_BASE=/entra
ENTRA_INTERNAL_URL=http://127.0.0.1:8029

# ============================================================
# PARAMETRI NON USATI DAL CODICE TS/JS — candidati alla rimozione.
# Servono solo a script di verifica (verify-env.sh) e alla documentazione.
# Dopo aver verificato che tutto funziona, possono essere cancellati.
# ============================================================
# NEXT_PUBLIC_APP_ORIGIN=http://10.1.1.11:3090
#   ^ Non letto da nessun file .ts/.js. Usato solo da scripts/verify-env.sh e docs.
# GOTRUE_EXTERNAL_AZURE_REDIRECT_URI=https://athena.uni.com/auth/v1/callback
#   ^ Parametro di Supabase GoTrue, non del frontend. Qui solo come promemoria
#     del valore che DEVE corrispondere a supabase-project/.env e al portale Azure.
